TELEGRAM_TOKEN=your_telegram_bot_token
PROXYAPI_TOKEN=your_proxyapi_token
CASUAL_MODEL_NAME=gpt-5.5
MAX_REPLY_CHARS=3500
PROXY_BASE_URL=https://api.proxyapi.ru/openai/v1

# Identity and chat access
ALLOWED_USERNAME=tunsuyoki
ALLOWED_USERNAMES=tunsuyoki
ALLOWED_CHAT_IDS=

# Security guard
SECURITY_MODEL_NAME=gpt-5.5
SECURITY_PROFANE_MODE=true
SPEC_MODEL_NAME=gpt-5.5

# Cursor Cloud run
CURSOR_API_KEY=
CURSOR_API_BASE=https://api.cursor.com/v1
CURSOR_AGENT_MODEL=gpt-5.5-medium
CURSOR_HTTP_TIMEOUT_SECONDS=45
CURSOR_POLL_INTERVAL_SECONDS=8
CURSOR_MAX_POLL_MINUTES=30

# GitHub integration
GITHUB_TOKEN=
GITHUB_REPO=tunsuyokii/hedgehog
GIT_ALLOWED_PATHS=src/**,.github/workflows/**,README.md,requirements.txt
GIT_BLOCKED_PATHS=.env,**/.env,**/secrets/**,**/*.pem,**/*.key

# S3 audit
S3_ENDPOINT=https://s3.twcstorage.ru
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=telegram-cursor
