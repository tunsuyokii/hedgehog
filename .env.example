TELEGRAM_TOKEN=your_telegram_bot_token
PROXYAPI_TOKEN=your_proxyapi_token
CASUAL_MODEL_NAME=gpt-5.5
MAX_REPLY_CHARS=3500
MAX_REPLY_WORDS=30
PROXY_BASE_URL=https://api.proxyapi.ru/openai/v1

# Identity and chat access
ALLOWED_USERNAME=
ALLOWED_USERNAMES=
ALLOWED_CHAT_IDS=
AUTO_APPROVE_REQUESTS=true
RATE_LIMIT_MAX_REQUESTS=8
RATE_LIMIT_WINDOW_SECONDS=60
REPO_QA_MODEL=gpt-5.5
CHAT_MODE_MODEL=gpt-5.5
CHAT_ASSISTANT_MODEL=gpt-4o-mini
DEVELOPMENT_TRIGGER=изменение

# Security guard
SECURITY_MODEL_NAME=gpt-5.5
SECURITY_PROFANE_MODE=true
SPEC_MODEL_NAME=gpt-5.5

# Cursor Cloud run
CURSOR_API_KEY=
CURSOR_API_BASE=https://api.cursor.com/v1
CURSOR_AGENT_MODEL=
CURSOR_HTTP_TIMEOUT_SECONDS=45
CURSOR_POLL_INTERVAL_SECONDS=8
CURSOR_MAX_POLL_MINUTES=30
CURSOR_PR_DETECTED_GRACE_SECONDS=120
CURSOR_STALE_SECONDS=120

# GitHub integration
GITHUB_TOKEN=
GITHUB_REPO=tunsuyokii/hedgehog
GIT_ALLOWED_PATHS=src/**,.github/workflows/**,README.md,requirements.txt
GIT_BLOCKED_PATHS=.env,**/.env,**/secrets/**,**/*.pem,**/*.key
GIT_FRONTEND_PATHS=frontend/**,docs/**,public/**,*.html,*.css,*.js,*.ts,*.tsx
LOCAL_BACKEND_APPLY_COMMAND=python src/local_backend_apply.py --task-file "{task_file}"
LOCAL_BACKEND_TIMEOUT_SECONDS=1800

# S3 audit
S3_ENDPOINT=https://s3.twcstorage.ru
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=telegram-cursor
